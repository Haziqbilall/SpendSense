# Backend required env vars (Render)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
FRONTEND_URL=http://localhost:5173
GROQ_API_KEY=your_groq_key_here
JWT_SECRET=replace_with_a_long_random_secret

# Optional (recommended)
PORT=3000

# Plain-text AI responses (strips markdown like **bold**)
# Set to "false" if your frontend wants markdown formatting.
AI_PLAIN_TEXT=true

# Render keep-alive (prevents web-service cold starts / sleeping)
# IMPORTANT: in production set SELF_URL to your public Render URL + /api/health
KEEPALIVE_ENABLED=true
KEEPALIVE_INTERVAL_SECONDS=300
SELF_URL=http://localhost:3000/api/health

# Render DB keep-alive (touch Postgres daily so it doesn't sleep)
DB_KEEPALIVE_ENABLED=true
DB_KEEPALIVE_CRON=0 3 * * *

